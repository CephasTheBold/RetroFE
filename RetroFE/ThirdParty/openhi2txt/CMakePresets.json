{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "cacheVariables": {
        "CMAKE_SYSTEM_VERSION": "10.0.26100.0",
        "OPENHI2TXT_BUILD_CLI": "ON"
      }
    },
    {
      "name": "windows-ninja",
      "displayName": "Windows Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-ninja",
      "cacheVariables": {
        "OPENHI2TXT_BUILD_CLI": "ON"
      }
    },
    {
      "name": "linux-ninja",
      "displayName": "Linux Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "OPENHI2TXT_BUILD_CLI": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Release"
    },
    {
      "name": "windows-ninja",
      "configurePreset": "windows-ninja"
    },
    {
      "name": "linux-ninja",
      "configurePreset": "linux-ninja"
    }
  ]
}
